{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.codex/hooks/session_start_context.py\"",
            "statusMessage": "Loading agent memory"
          }
        ]
      }
    ]
  }
}
