#!/usr/bin/env bash
# claude-sandbox.sh — Rootless sandbox for Claude Code
#
# Isolates: filesystem, PID, IPC, UTS, user
# Shares:   host network (simple, reliable, no slirp4netns)
#
# Visible inside sandbox:
#   /nix/store       — read-only
#   $WORKSPACE       — read-write (original path preserved)
#   /home/$USER/.agents — read-only (shared workflow definitions)
#   /home/$USER/.claude — read-write (persistent global config)
#   /proc /dev /tmp /run — essentials
#   /etc/{resolv.conf,ssl,passwd,group} — networking & identity
# Everything else (home, usr, etc, other projects, docker socket) — gone

set -euo pipefail

WORKSPACE="$(pwd)"
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
	case "$1" in
	--workspace)
		WORKSPACE="$2"
		shift 2
		;;
	*)
		CLAUDE_ARGS+=("$1")
		shift
		;;
	esac
done

WORKSPACE="$(realpath "$WORKSPACE")"
[[ -d "$WORKSPACE" ]] || {
	echo "ERROR: Workspace '$WORKSPACE' not found" >&2
	exit 1
}

resolve_bin() {
	local path
	path="$(command -v "$1" 2>/dev/null)" || {
		echo "ERROR: '$1' not found" >&2
		exit 1
	}
	readlink -f "$path"
}

add_path_dir() {
	local dir="$1"
	[[ -d "$dir" ]] || return 0

	if [[ -z "${SEEN[$dir]:-}" ]]; then
		SEEN[$dir]=1
		SANDBOX_PATH="${SANDBOX_PATH:+$SANDBOX_PATH:}$dir"
	fi
}

resolve_current_bash() {
	[[ -n "${BASH:-}" ]] || {
		echo "ERROR: BASH is not set" >&2
		exit 1
	}
	readlink -f "$BASH"
}

BWRAP="$(resolve_bin bwrap)"
SANDBOX_SHELL="$(resolve_bin "$(basename "${SHELL:-zsh}")")"
SANDBOX_SHELL_NAME="$(basename "$SANDBOX_SHELL")"
CLAUDE="$(resolve_bin claude)"
NODE="$(resolve_bin node)"
CAT="$(resolve_bin cat)"
ENV_BIN="$(resolve_bin env)"
BASH_BIN="$(resolve_current_bash)"
SH_BIN="$BASH_BIN"

# Resolve nix profile bin directory — all nix-installed programs live here as
# symlinks into /nix/store (which is already ro-mounted), so a single PATH
# entry gives the sandbox access to everything installed via nix/home-manager.
NIX_PROFILE_BIN="$(readlink -f "$HOME/.nix-profile/bin")"
[[ -d "$NIX_PROFILE_BIN" ]] || {
	echo "ERROR: nix profile bin not found at $NIX_PROFILE_BIN" >&2
	exit 1
}

# Build deduplicated PATH from hard dependencies, host PATH entries that resolve
# into /nix/store, and the nix profile bin.
declare -A SEEN
SANDBOX_PATH=""

for entry in "$CLAUDE" "$NODE" "$SANDBOX_SHELL" "$CAT" "$ENV_BIN" "$BASH_BIN" "$SH_BIN"; do
	add_path_dir "$(dirname "$entry")"
done

IFS=':' read -r -a HOST_PATH_ENTRIES <<<"${PATH:-}"
for entry in "${HOST_PATH_ENTRIES[@]}"; do
	[[ -n "$entry" && -d "$entry" ]] || continue
	resolved="$(readlink -f "$entry" 2>/dev/null || true)"
	[[ -d "$resolved" ]] || continue

	case "$resolved" in
	/nix/store/*) add_path_dir "$resolved" ;;
	esac
done

add_path_dir "$NIX_PROFILE_BIN"

# Resolve resolv.conf (may be symlink under systemd-resolved)
RESOLV="$(readlink -f /etc/resolv.conf)"

# Pass through API keys if set
ENV_ARGS=()
for var in ANTHROPIC_API_KEY CLAUDE_API_KEY GITHUB_TOKEN; do
	[[ -n "${!var:-}" ]] && ENV_ARGS+=(--setenv "$var" "${!var}")
done

# Ensure ~/.claude and ~/.claude.json exist for bind mounts
mkdir -p "$HOME/.claude"
touch "$HOME/.claude.json"

AGENTS_BIND_ARGS=(--dir "/home/$USER/.agents")
if [[ -e "$HOME/.agents" ]]; then
	AGENTS_BIND_ARGS=(--ro-bind "$HOME/.agents" "/home/$USER/.agents")
fi

echo "[sandbox] workspace: $WORKSPACE"
echo "[sandbox] starting claude..."

exec "$BWRAP" \
	--unshare-user \
	--unshare-pid \
	--unshare-ipc \
	--unshare-uts \
	--hostname claude-sandbox \
	--ro-bind /nix/store /nix/store \
	--proc /proc \
	--dev /dev \
	--tmpfs /tmp \
	--tmpfs /run \
	--tmpfs "/home/$USER" \
	--dir "/home/$USER/.nix-profile" \
	--dir /usr \
	--dir /usr/bin \
	--dir /bin \
	--ro-bind "$NIX_PROFILE_BIN" "/home/$USER/.nix-profile/bin" \
	--ro-bind "$ENV_BIN" /usr/bin/env \
	--ro-bind "$BASH_BIN" /bin/bash \
	--ro-bind "$SH_BIN" /bin/sh \
	--ro-bind "$SANDBOX_SHELL" "/bin/$SANDBOX_SHELL_NAME" \
	--bind "$WORKSPACE" "$WORKSPACE" \
	"${AGENTS_BIND_ARGS[@]}" \
	--bind "$HOME/.claude" "/home/$USER/.claude" \
	--bind "$HOME/.claude.json" "/home/$USER/.claude.json" \
	--ro-bind "$RESOLV" /etc/resolv.conf \
	--ro-bind /etc/ssl /etc/ssl \
	--ro-bind /etc/passwd /etc/passwd \
	--ro-bind /etc/group /etc/group \
	--chdir "$WORKSPACE" \
	--setenv HOME "/home/$USER" \
	--setenv SHELL "/home/$USER/.nix-profile/bin/$SANDBOX_SHELL_NAME" \
	--setenv TERM "${TERM:-xterm-256color}" \
	--setenv PATH "/home/$USER/.nix-profile/bin:$SANDBOX_PATH" \
	--setenv LANG "${LANG:-en_US.UTF-8}" \
	--setenv NIX_SSL_CERT_FILE /etc/ssl/certs/ca-certificates.crt \
	"${ENV_ARGS[@]}" \
	-- "$CLAUDE" "${CLAUDE_ARGS[@]}"
