#!/usr/bin/env bash
# codex-sandbox.sh — Rootless sandbox for Codex CLI
#
# Isolates: filesystem, PID, IPC, UTS, user
# Shares:   host network (simple, reliable, no slirp4netns)
#
# Visible inside sandbox:
#   /nix/store       — read-only
#   $WORKSPACE       — read-write (original path preserved)
#   /home/$USER/.agents — read-only (shared workflow definitions)
#   /home/$USER/.codex — read-write (persistent global config)
#   /home/$USER/.cache/nix, .config/nix, .local/{share,state}/nix — persistent Nix state
#   /proc /dev /tmp /run — essentials
#   /etc/{resolv.conf,ssl,passwd,group} — networking & identity
#   Optional: a temporary ssh-agent socket plus ~/.ssh/{config,known_hosts} when
#   launched with --ssh-key /path/to/key
# Everything else (home, usr, etc, other projects, docker socket) — gone

set -euo pipefail

WORKSPACE="$(pwd)"
CODEX_ARGS=()
DNS_DEBUG=0
SSH_KEY_PATH=""
SSH_AGENT_BIN=""
SSH_ADD_BIN=""
SSH_AGENT_DIR=""
SSH_AGENT_PID_VALUE=""
SSH_AGENT_SOCKET_HOST=""
SSH_AGENT_SOCKET_SANDBOX=""

cleanup_ssh_agent() {
	[[ -n "${SSH_AGENT_PID_VALUE:-}" ]] || return 0

	SSH_AGENT_PID="$SSH_AGENT_PID_VALUE" \
	SSH_AUTH_SOCK="$SSH_AGENT_SOCKET_HOST" \
	"$SSH_AGENT_BIN" -k >/dev/null 2>&1 || true
	rm -rf "$SSH_AGENT_DIR"
}

setup_ssh_agent() {
	local key_path="$1"
	local ssh_agent_output

	SSH_AGENT_BIN="$(resolve_bin ssh-agent)"
	SSH_ADD_BIN="$(resolve_bin ssh-add)"

	SSH_AGENT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/codex-sandbox-ssh.XXXXXX")"
	SSH_AGENT_SOCKET_HOST="$SSH_AGENT_DIR/agent.sock"
	SSH_AGENT_SOCKET_SANDBOX="/tmp/codex-sandbox-ssh/agent.sock"

	ssh_agent_output="$("$SSH_AGENT_BIN" -s -a "$SSH_AGENT_SOCKET_HOST")"
	eval "$ssh_agent_output" >/dev/null
	SSH_AGENT_PID_VALUE="${SSH_AGENT_PID:-}"
	[[ -n "$SSH_AGENT_PID_VALUE" && -S "$SSH_AGENT_SOCKET_HOST" ]] || {
		echo "ERROR: failed to start temporary ssh-agent" >&2
		exit 1
	}

	trap cleanup_ssh_agent EXIT
	"$SSH_ADD_BIN" "$key_path"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	--workspace)
		WORKSPACE="$2"
		shift 2
		;;
	--dns-debug)
		DNS_DEBUG=1
		shift
		;;
	--ssh-key)
		SSH_KEY_PATH="$2"
		shift 2
		;;
	*)
		CODEX_ARGS+=("$1")
		shift
		;;
	esac
done

WORKSPACE="$(realpath "$WORKSPACE")"
[[ -d "$WORKSPACE" ]] || {
	echo "ERROR: Workspace '$WORKSPACE' not found" >&2
	exit 1
}

if [[ -n "$SSH_KEY_PATH" ]]; then
	SSH_KEY_PATH="$(realpath "$SSH_KEY_PATH")"
	[[ -f "$SSH_KEY_PATH" ]] || {
		echo "ERROR: SSH key '$SSH_KEY_PATH' not found" >&2
		exit 1
	}
fi

resolve_bin() {
	local path
	path="$(command -v "$1" 2>/dev/null)" || {
		echo "ERROR: '$1' not found" >&2
		exit 1
	}
	readlink -f "$path"
}

add_path_dir() {
	local dir="$1"
	[[ -d "$dir" ]] || return 0

	if [[ -z "${SEEN[$dir]:-}" ]]; then
		SEEN[$dir]=1
		SANDBOX_PATH="${SANDBOX_PATH:+$SANDBOX_PATH:}$dir"
	fi
}

resolve_current_bash() {
	[[ -n "${BASH:-}" ]] || {
		echo "ERROR: BASH is not set" >&2
		exit 1
	}
	readlink -f "$BASH"
}

BWRAP="$(resolve_bin bwrap)"
SANDBOX_SHELL="$(resolve_bin "$(basename "${SHELL:-zsh}")")"
SANDBOX_SHELL_NAME="$(basename "$SANDBOX_SHELL")"
CODEX="$(resolve_bin codex)"
NODE="$(resolve_bin node)"
CAT="$(resolve_bin cat)"
ENV_BIN="$(resolve_bin env)"
BASH_BIN="$(resolve_current_bash)"
SH_BIN="$BASH_BIN"

# Resolve nix profile bin directory — all nix-installed programs live here as
# symlinks into /nix/store (which is already ro-mounted), so a single PATH
# entry gives the sandbox access to everything installed via nix/home-manager.
NIX_PROFILE_BIN="$(readlink -f "$HOME/.nix-profile/bin")"
[[ -d "$NIX_PROFILE_BIN" ]] || {
	echo "ERROR: nix profile bin not found at $NIX_PROFILE_BIN" >&2
	exit 1
}

# Build deduplicated PATH from hard dependencies, host PATH entries that resolve
# into /nix/store, and the nix profile bin.
declare -A SEEN
SANDBOX_PATH=""

for entry in "$CODEX" "$NODE" "$SANDBOX_SHELL" "$CAT" "$ENV_BIN" "$BASH_BIN" "$SH_BIN"; do
	add_path_dir "$(dirname "$entry")"
done

IFS=':' read -r -a HOST_PATH_ENTRIES <<<"${PATH:-}"
for entry in "${HOST_PATH_ENTRIES[@]}"; do
	[[ -n "$entry" && -d "$entry" ]] || continue
	resolved="$(readlink -f "$entry" 2>/dev/null || true)"
	[[ -d "$resolved" ]] || continue

	case "$resolved" in
	/nix/store/*) add_path_dir "$resolved" ;;
	esac
done

add_path_dir "$NIX_PROFILE_BIN"

# Resolve resolv.conf (may be symlink under systemd-resolved)
RESOLV="$(readlink -f /etc/resolv.conf)"

# Pass through API keys if set
ENV_ARGS=()
for var in OPENAI_API_KEY GITHUB_TOKEN; do
	[[ -n "${!var:-}" ]] && ENV_ARGS+=(--setenv "$var" "${!var}")
done

# Ensure persistent host-backed directories exist for bind mounts
mkdir -p \
	"$HOME/.codex" \
	"$HOME/.cache/nix" \
	"$HOME/.config/nix" \
	"$HOME/.local/share/nix" \
	"$HOME/.local/state/nix"

AGENTS_BIND_ARGS=(--dir "/home/$USER/.agents")
if [[ -e "$HOME/.agents" ]]; then
	AGENTS_BIND_ARGS=(--ro-bind "$HOME/.agents" "/home/$USER/.agents")
fi

HOME_DIR_ARGS=(
	--dir "/home/$USER/.nix-profile"
	--dir "/home/$USER/.cache"
	--dir "/home/$USER/.config"
	--dir "/home/$USER/.local"
	--dir "/home/$USER/.local/share"
	--dir "/home/$USER/.local/state"
)

NIX_BIND_ARGS=(
	--bind "$HOME/.cache/nix" "/home/$USER/.cache/nix"
	--bind "$HOME/.config/nix" "/home/$USER/.config/nix"
	--bind "$HOME/.local/share/nix" "/home/$USER/.local/share/nix"
	--bind "$HOME/.local/state/nix" "/home/$USER/.local/state/nix"
)

SSH_HOME_DIR_ARGS=()
SSH_BIND_ARGS=()
SSH_ENV_ARGS=()
if [[ -n "$SSH_KEY_PATH" ]]; then
	setup_ssh_agent "$SSH_KEY_PATH"
	SSH_HOME_DIR_ARGS=(--dir "/home/$USER/.ssh")
	SSH_BIND_ARGS=(
		--dir /tmp/codex-sandbox-ssh
		--bind "$SSH_AGENT_SOCKET_HOST" "$SSH_AGENT_SOCKET_SANDBOX"
	)
	SSH_ENV_ARGS=(--setenv SSH_AUTH_SOCK "$SSH_AGENT_SOCKET_SANDBOX")

	if [[ -f "$HOME/.ssh/known_hosts" ]]; then
		SSH_BIND_ARGS+=(--ro-bind "$HOME/.ssh/known_hosts" "/home/$USER/.ssh/known_hosts")
	fi

	if [[ -f "$HOME/.ssh/config" ]]; then
		SSH_BIND_ARGS+=(--ro-bind "$HOME/.ssh/config" "/home/$USER/.ssh/config")
	fi
fi

echo "[sandbox] workspace: $WORKSPACE"

SANDBOX_CMD=("$CODEX" "${CODEX_ARGS[@]}")
if [[ "$DNS_DEBUG" -eq 1 ]]; then
	echo "[sandbox] running DNS diagnostics..."
	SANDBOX_CMD=(/bin/bash -lc '
			echo "== curl -I https://1.1.1.1 =="
			curl -I --max-time 10 https://1.1.1.1 || true
			echo
			echo "== doggo www.google.com =="
			doggo www.google.com || true
			echo
			echo "== ls /etc =="
			ls -la /etc || true
			echo
			echo "== ls /run /run/systemd /run/systemd/resolve =="
			ls -la /run /run/systemd /run/systemd/resolve 2>/dev/null || true
		')
else
	echo "[sandbox] starting codex..."
fi

if [[ -n "$SSH_KEY_PATH" ]]; then
	echo "[sandbox] ssh: temporary agent enabled for key $SSH_KEY_PATH"
fi

"$BWRAP" \
	--unshare-user \
	--unshare-pid \
	--unshare-ipc \
	--unshare-uts \
	--hostname codex-sandbox \
	--ro-bind /nix/store /nix/store \
	--proc /proc \
	--dev /dev \
	--tmpfs /tmp \
	--tmpfs /run \
	--tmpfs "/home/$USER" \
	"${HOME_DIR_ARGS[@]}" \
	"${SSH_HOME_DIR_ARGS[@]}" \
	--dir /usr \
	--dir /usr/bin \
	--dir /bin \
	--ro-bind "$NIX_PROFILE_BIN" "/home/$USER/.nix-profile/bin" \
	--ro-bind "$ENV_BIN" /usr/bin/env \
	--ro-bind "$BASH_BIN" /bin/bash \
	--ro-bind "$SH_BIN" /bin/sh \
	--ro-bind "$SANDBOX_SHELL" "/bin/$SANDBOX_SHELL_NAME" \
	--bind "$WORKSPACE" "$WORKSPACE" \
	"${AGENTS_BIND_ARGS[@]}" \
	--bind "$HOME/.codex" "/home/$USER/.codex" \
	"${NIX_BIND_ARGS[@]}" \
	"${SSH_BIND_ARGS[@]}" \
	--ro-bind "$RESOLV" /etc/resolv.conf \
	--ro-bind /etc/ssl /etc/ssl \
	--ro-bind /etc/passwd /etc/passwd \
	--ro-bind /etc/group /etc/group \
	--chdir "$WORKSPACE" \
	--setenv HOME "/home/$USER" \
	--setenv SHELL "/home/$USER/.nix-profile/bin/$SANDBOX_SHELL_NAME" \
	--setenv TERM "${TERM:-xterm-256color}" \
	--setenv PATH "/home/$USER/.nix-profile/bin:$SANDBOX_PATH" \
	--setenv LANG "${LANG:-en_US.UTF-8}" \
	--setenv NIX_SSL_CERT_FILE /etc/ssl/certs/ca-certificates.crt \
	"${ENV_ARGS[@]}" \
	"${SSH_ENV_ARGS[@]}" \
	-- "${SANDBOX_CMD[@]}"
# -- "zsh" "-c" "ls"
# -- "ls" "-la" "$SHELL"
# -- "cat" "../.codex/auth.json"
# -- "ls" "-la" "../.codex"
