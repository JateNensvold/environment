#!/usr/bin/env zsh
# shellcheck disable=SC1071
# Legacy non-flake Nix bootstrap. Prefer `flakify` unless the user explicitly
# asks for `shell.nix` or `default.nix`.

if [ ! -e ./.envrc ]; then
	echo "use nix" >.envrc
	direnv allow
fi
if [[ ! -e shell.nix ]] && [[ ! -e default.nix ]]; then
	cat >default.nix <<'EOF'
with import <nixpkgs> {};
mkShell {
  nativeBuildInputs = [
    bashInteractive
  ];
}
EOF
	${EDITOR:-vim} default.nix
fi
